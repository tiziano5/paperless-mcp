# URL of your Paperless-ngx instance (no trailing slash)
PAPERLESS_URL=http://<NAS-IP>:8010

# API token — generate it in Paperless: profile menu -> "API Auth Token"
# Tip: create a dedicated read-only user (see README, Security section)
PAPERLESS_TOKEN=your_token_here

# HTTP transport only (Docker deployment)
MCP_HOST=0.0.0.0
MCP_PORT=8802
